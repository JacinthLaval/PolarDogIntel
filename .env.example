# PolarDog Intel — Environment Variables
# Copy to .env.local and fill in your values. Never commit .env.local to git.

# ─── Snowflake MCP Server ─────────────────────────────────────────────────────
# Your Snowflake account identifier (e.g. xy12345.us-east-1)
EXPO_PUBLIC_SNOWFLAKE_ACCOUNT=YOUR_ACCOUNT.REGION

# The managed MCP server endpoint exposed from your Snowflake account
# Format: https://<account>.snowflakecomputing.com/api/v2/mcp/sse  (SSE transport)
#     or: https://<account>.snowflakecomputing.com/api/v2/mcp       (HTTP transport)
EXPO_PUBLIC_MCP_SERVER_URL=https://YOUR_ACCOUNT.snowflakecomputing.com/api/v2/mcp/sse

# MCP transport: "sse" | "http"
EXPO_PUBLIC_MCP_TRANSPORT=sse

# ─── Authentication ────────────────────────────────────────────────────────────
# PAT (Personal Access Token) is stored securely in expo-secure-store at runtime.
# You do NOT put the token here — users enter it in the app's Settings screen.
# This variable is only used for local dev/testing convenience (never committed).
# SNOWFLAKE_PAT=your_pat_here

# ─── App Config ───────────────────────────────────────────────────────────────
EXPO_PUBLIC_APP_ENV=development
# EXPO_PUBLIC_APP_ENV=production
